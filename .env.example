DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com,your-droplet-ip

FRONTEND_URL=https://your-domain.com
BACKEND_PUBLIC_URL=https://your-domain.com
SOCKET_SERVER_URL=http://127.0.0.1:8001

CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com

DATABASE_URL=postgresql://digitalqr:change-me@localhost:5432/digitalqr
DB_SSLMODE=prefer
DB_CONN_MAX_AGE=60

STATIC_ROOT=/var/www/digitalqr/static
MEDIA_ROOT=/var/www/digitalqr/media

SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=3600
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=False
SECURE_REFERRER_POLICY=same-origin

DJANGO_TIME_ZONE=UTC

SOCKET_SERVER_HOST=127.0.0.1
SOCKET_SERVER_PORT=8001
SOCKET_CORS_ALLOWED_ORIGINS=https://your-domain.com